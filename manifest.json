{
  "manifest_version": 3,
  "name": "쇼츠 처형자 (Shorts Executioner)",
  "version": "1.0.0",
  "description": "양산형 유튜브 쇼츠/추천 영상을 한 번의 클릭으로 싫어요 + 관심 없음 + 채널 추천 안함 처리합니다.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "쇼츠 처형자 설정",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["src/intercept.js"],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["src/config.js", "src/util.js", "src/blocklist.js", "src/youtube.js", "src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "shorts-executioner@cnusec.kr",
      "strict_min_version": "128.0"
    }
  }
}
